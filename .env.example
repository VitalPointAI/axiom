# Database
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgres://neartax:your_secure_password_here@localhost:5432/neartax

# API Keys
NEARBLOCKS_API_KEY=your_nearblocks_api_key
ALCHEMY_API_KEY=your_alchemy_api_key
ETHERSCAN_API_KEY=your_etherscan_api_key
COINGECKO_API_KEY=your_coingecko_api_key
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key

# Optional
FASTNEAR_API_KEY=your_fastnear_api_key

# Indexer Config
JOB_POLL_INTERVAL=5
SYNC_INTERVAL_MINUTES=15

# Application
NODE_ENV=production

# Deployment
DEPLOY_HOST=your_server_hostname_or_ip
DEPLOY_USER=your_ssh_user
DEPLOY_PATH=/path/to/axiom/on/server
DEPLOY_SSH_KEY=/path/to/ssh/key
